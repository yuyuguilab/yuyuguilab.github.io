  <span class="share-copied" id="share-copied">{{ __('share.copied') }}</span>
</div>
<script>
(function(){
  var wrap=document.getElementById('post-share');
  if(!wrap)return;
  var u=encodeURIComponent(location.href);
  var t=encodeURIComponent(document.title);
  var map={
    x:'https://x.com/intent/tweet?url='+u+'&text='+t,
    facebook:'https://www.facebook.com/sharer/sharer.php?u='+u,
    linkedin:'https://www.linkedin.com/sharing/share-offsite/?url='+u,
    telegram:'https://t.me/share/url?url='+u+'&text='+t,
    whatsapp:'https://wa.me/?text='+t+'%20'+u,
    reddit:'https://www.reddit.com/submit?url='+u+'&title='+t,
    weibo:'https://service.weibo.com/share/share.php?url='+u+'&title='+t,
    email:'mailto:?subject='+t+'&body='+u
  };
  wrap.querySelectorAll('[data-share]').forEach(function(el){
    var k=el.getAttribute('data-share');
    if(k==='native'){
      el.style.display = (navigator.share)?'inline-flex':'none';
      el.addEventListener('click',function(){
        navigator.share({title:document.title,url:location.href}).catch(function(){});
      });
    }else if(k==='copy'){
      el.addEventListener('click',function(){
        var done=document.getElementById('share-copied');
        navigator.clipboard.writeText(location.href).then(function(){
          if(done){done.classList.add('show');setTimeout(function(){done.classList.remove('show');},1800);}
        }).catch(function(){
          // 兜底：旧浏览器用 execCommand
          var ta=document.createElement('textarea');ta.value=location.href;document.body.appendChild(ta);ta.select();
          try{document.execCommand('copy');if(done){done.classList.add('show');setTimeout(function(){done.classList.remove('show');},1800);}}catch(e){}
          document.body.removeChild(ta);
        });
      });
    }else if(map[k]){
      el.setAttribute('href',map[k]);
    }
  });
})();
</script>
