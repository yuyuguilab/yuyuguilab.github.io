{# 共用顶部导航：品牌名 + 导航链接 + 语言切换 + 主题切换 #}
<nav class="top-nav">
  <a class="nav-name" href="{{ url_for('/') }}">{{ theme.identity[config.lang].title }}</a>
  <div class="nav-links">
    {% for item in theme.nav[config.lang] %}
      <a href="{{ url_for('/') }}#{{ item.id }}">{{ item.label }}</a>
    {% endfor %}

    {# 语言切换：目标 URL 由 build.js 注入到 body[data-lang-target] #}
    <a href="#" id="nav-lang" class="nav-action" title="{{ __('nav.lang_switch') }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20"/></svg>
      <span>{{ __('nav.lang_label') }}</span>
    </a>

    {# 主题切换：下拉菜单 #}
    <span class="nav-theme-wrap">
      <button id="nav-theme-btn" class="nav-action" title="{{ __('nav.theme_switch') }}" aria-haspopup="true" aria-expanded="false">
        <svg id="nav-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg id="nav-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z"/></svg>
      </button>
      <span id="nav-theme-menu" class="nav-theme-menu" role="menu">
        <button data-theme-set="light" role="menuitem"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>{{ __('nav.light') }}</button>
        <button data-theme-set="dark" role="menuitem"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z"/></svg>{{ __('nav.dark') }}</button>
        <button data-theme-set="auto" role="menuitem"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="M7 6v12M11 6v12"/></svg>{{ __('nav.auto') }}</button>
      </span>
    </span>
  </div>
</nav>
