{% extends '_layout.njk' %}

{% block title %}{{ page.title }} · {{ config.title }}{% endblock %}

{% block content %}
{% set cats = page.categories.toArray() %}
{% set tags = page.tags.toArray() %}
{% include '_partials/nav.njk' %}

<article class="card post">
  <header class="post-head">
    {% if cats.length %}
      <p class="crumbs">
        {{ __('post.in') }}：
        {% for c in cats %}
          <a href="{{ url_for('categories/' + c.slug + '/') }}">{{ cat_display(c.slug) }}</a>{% if not loop.last %} · {% endif %}
        {% endfor %}
      </p>
    {% endif %}
    <h1>{{ page.title }}</h1>
    <p class="post-meta" style="margin-left:0;display:block;margin-top:6px">
      <time datetime="{{ date(page.date, 'YYYY-MM-DD') }}">{{ date(page.date, 'YYYY-MM-DD') }}</time>
      {% if page.updated and date(page.updated, 'YYYY-MM-DD') != date(page.date, 'YYYY-MM-DD') %}
        · {{ __('post.updated') }} {{ date(page.updated, 'YYYY-MM-DD') }}
      {% endif %}
      · <span id="busuanzi_container_page_pv" style="display:none">{{ __('stats.page_pv') }} <span id="busuanzi_value_page_pv"></span></span>
    </p>
  </header>

  <div class="post-body">
    {{ page.content }}
  </div>

  {% if tags.length %}
    <div style="margin-top:1.5rem">
      {% for t in tags %}
        <a class="tag" href="{{ url_for('tags/' + t.slug + '/') }}">{{ t.name }}</a>
      {% endfor %}
    </div>
  {% endif %}

  {% include '_partials/share.njk' %}

  <p class="post-back">
    {% if cats.length %}
      <a href="{{ url_for('categories/' + cats[0].slug + '/') }}">{{ __('post.back_cat') }}</a>
    {% endif %}
  </p>
</article>

{% include '_partials/related.njk' %}
{% endblock %}
