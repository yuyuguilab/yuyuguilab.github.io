{% extends '_layout.njk' %}

{% block title %}{{ cat_display(page.category) }} · {{ config.title }}{% endblock %}

{% block content %}
{% include '_partials/nav.njk' %}

<section class="card">
  <h2>{{ cat_display(page.category) }}</h2>
  {% if page.posts and page.posts.length %}
    <ul class="post-list">
      {% for post in page.posts.toArray() %}
        <li>
          <a href="{{ url_for(post.path) }}">{{ post.title }}</a>
          <span class="post-meta">{{ date(post.date, 'YYYY-MM-DD') }}</span>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p style="color:var(--muted)">{{ __('category.empty') }}</p>
  {% endif %}
  <p class="post-back"><a href="{{ url_for('/') }}">{{ __('post.back_home') }}</a></p>
</section>
{% endblock %}
